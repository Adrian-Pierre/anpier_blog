---
const siteKey = "0x4AAAAAACZlhb6gyAukDyMx";
const next = Astro.url.searchParams.get("next") ?? "/about/";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Verification - Anpier</title>

    <script is:inline define:vars={{ next }}>
      const gateRuntime = (window.__anpierGateRuntime ??= {
        pending: false,
      });

      window.handleTurnstileToken = async (token) => {
        if (!token || gateRuntime.pending) return;
        gateRuntime.pending = true;

        try {
          const res = await fetch("/api/turnstile-verify", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ token, next }),
          });

          if (!res.ok) throw new Error("verify failed");

          const data = await res.json();
          location.replace(data.redirect || "/about/");
        } catch (_error) {
          gateRuntime.pending = false;
          alert("验证失败，请刷新页面重试");
        }
      };
    </script>

    <!-- Cloudflare Turnstile -->
    <script
      is:inline
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    ></script>
  </head>

  <body class="gate">
    <div class="gate-shell">
      <div class="gate-orb gate-orb--peach"></div>
      <div class="gate-orb gate-orb--mint"></div>
      <div class="gate-orb gate-orb--blue"></div>

      <main class="card">
        <div class="gate-kicker-row">
          <span class="gate-kicker">Anpier</span>
          <span class="gate-chip">
            <span class="gate-chip-dot"></span>
            Verifying
          </span>
        </div>

        <h1>请完成安全验证</h1>
        <p class="desc">
          这是一次很轻的安全校验，用来过滤异常访问。正常情况下只需要几秒钟，完成后会自动进入博客。
        </p>

        <section class="gate-panel">
          <div class="gate-panel-head">
            <div class="gate-panel-title">Security Check</div>
            <div class="gate-loader" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>

          <p class="gate-panel-note">
            Cloudflare Turnstile 会在需要时显示勾选框，否则会自动通过。
          </p>

          <div class="turnstile-wrap">
            <div class="cf-turnstile" data-sitekey={siteKey} data-callback="handleTurnstileToken"></div>
          </div>
        </section>

        <p class="footnote">如果长时间没有自动完成，可以刷新页面后重试。</p>
      </main>
    </div>

    <style>
      :root {
        color-scheme: light dark;
        --gate-bg: #f6f2f0;
        --gate-card-bg: rgba(255, 252, 252, 0.82);
        --gate-card-border: rgba(255, 255, 255, 0.92);
        --gate-text: #46545b;
        --gate-soft-text: rgba(70, 84, 91, 0.72);
        --gate-accent: #8ec8bc;
        --gate-accent-2: #b9d5ef;
        --gate-accent-3: #f0c7ba;
        --gate-shadow: 0 38px 80px -52px rgba(40, 55, 62, 0.22);
      }

      body.gate {
        min-height: 100vh;
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background:
          radial-gradient(circle at 10% 0%, rgba(240, 199, 186, 0.28), transparent 24rem),
          radial-gradient(circle at 100% 10%, rgba(185, 213, 239, 0.22), transparent 22rem),
          radial-gradient(circle at 60% 100%, rgba(142, 200, 188, 0.22), transparent 28rem),
          linear-gradient(180deg, #fcfbfa, var(--gate-bg));
        font-family: "Avenir Next", "PingFang SC", "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        color: var(--gate-text);
      }

      .gate-shell {
        position: relative;
        width: min(100%, 58rem);
        padding: 2rem;
      }

      .gate-orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(16px);
        opacity: 0.78;
        pointer-events: none;
      }

      .gate-orb--peach {
        left: 0;
        top: 0.75rem;
        width: 10rem;
        height: 10rem;
        background: radial-gradient(circle, rgba(240, 199, 186, 0.68), rgba(240, 199, 186, 0));
      }

      .gate-orb--mint {
        right: 3rem;
        top: -1rem;
        width: 13rem;
        height: 13rem;
        background: radial-gradient(circle, rgba(142, 200, 188, 0.42), rgba(142, 200, 188, 0));
      }

      .gate-orb--blue {
        right: -1rem;
        bottom: -1.5rem;
        width: 14rem;
        height: 14rem;
        background: radial-gradient(circle, rgba(185, 213, 239, 0.5), rgba(185, 213, 239, 0));
      }

      .card {
        position: relative;
        z-index: 1;
        background: var(--gate-card-bg);
        width: 100%;
        max-width: 34rem;
        margin: 0 auto;
        padding: 2rem 2rem 1.8rem;
        border-radius: 2rem;
        border: 1px solid var(--gate-card-border);
        box-shadow: var(--gate-shadow);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
      }

      h1 {
        margin: 0.9rem 0 0;
        font-size: clamp(2rem, 5vw, 2.7rem);
        line-height: 1.04;
        font-weight: 800;
        letter-spacing: 0.01em;
        color: var(--gate-text);
      }

      .desc {
        margin: 1rem 0 0;
        max-width: 32rem;
        font-size: 1rem;
        color: var(--gate-soft-text);
        line-height: 1.9;
      }

      .gate-kicker-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .gate-kicker {
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: var(--gate-accent);
      }

      .gate-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.46rem 0.78rem;
        border-radius: 999px;
        border: 1px solid rgba(142, 200, 188, 0.22);
        background: rgba(255, 255, 255, 0.56);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6a928a;
      }

      .gate-chip-dot {
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 999px;
        background: var(--gate-accent);
        box-shadow: 0 0 0 0 rgba(142, 200, 188, 0.32);
        animation: gate-pulse 1.8s ease-out infinite;
      }

      .gate-panel {
        margin-top: 1.55rem;
        padding: 1.1rem 1.1rem 1rem;
        border-radius: 1.45rem;
        border: 1px solid rgba(142, 200, 188, 0.16);
        background:
          linear-gradient(160deg, rgba(255, 255, 255, 0.68), rgba(255, 255, 255, 0.38)),
          rgba(255, 255, 255, 0.42);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.84),
          0 24px 50px -42px rgba(40, 55, 62, 0.2);
      }

      .gate-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .gate-panel-title {
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: rgba(70, 84, 91, 0.78);
      }

      .gate-loader {
        display: inline-flex;
        align-items: center;
        gap: 0.32rem;
      }

      .gate-loader span {
        width: 0.34rem;
        height: 0.34rem;
        border-radius: 999px;
        background: var(--gate-accent);
        animation: gate-loader 1.1s ease-in-out infinite;
      }

      .gate-loader span:nth-child(2) {
        animation-delay: 0.12s;
      }

      .gate-loader span:nth-child(3) {
        animation-delay: 0.24s;
      }

      .gate-panel-note {
        margin: 0.6rem 0 0;
        font-size: 0.92rem;
        line-height: 1.7;
        color: var(--gate-soft-text);
      }

      .turnstile-wrap {
        margin-top: 1rem;
        display: flex;
        justify-content: center;
        min-height: 4.2rem;
      }

      .footnote {
        margin: 1rem 0 0;
        font-size: 0.88rem;
        line-height: 1.7;
        color: rgba(70, 84, 91, 0.58);
        text-align: center;
      }

      @keyframes gate-loader {
        0%, 80%, 100% {
          transform: translateY(0);
          opacity: 0.4;
        }
        40% {
          transform: translateY(-0.24rem);
          opacity: 1;
        }
      }

      @keyframes gate-pulse {
        0% {
          box-shadow: 0 0 0 0 rgba(142, 200, 188, 0.28);
        }
        70% {
          box-shadow: 0 0 0 0.52rem rgba(142, 200, 188, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(142, 200, 188, 0);
        }
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --gate-bg: #151a20;
          --gate-card-bg: rgba(24, 30, 36, 0.82);
          --gate-card-border: rgba(214, 226, 233, 0.1);
          --gate-text: #ecf2f6;
          --gate-soft-text: rgba(236, 242, 246, 0.72);
          --gate-shadow: 0 42px 92px -58px rgba(0, 0, 0, 0.54);
        }

        body.gate {
          background:
            radial-gradient(circle at 10% 0%, rgba(177, 134, 120, 0.18), transparent 24rem),
            radial-gradient(circle at 100% 10%, rgba(123, 155, 183, 0.15), transparent 22rem),
            radial-gradient(circle at 60% 100%, rgba(96, 146, 136, 0.16), transparent 28rem),
            linear-gradient(180deg, #171c22, var(--gate-bg));
        }

        .gate-chip,
        .gate-panel {
          background:
            linear-gradient(160deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015)),
            rgba(21, 27, 33, 0.64);
        }

        .gate-panel-title {
          color: rgba(236, 242, 246, 0.76);
        }

        .footnote {
          color: rgba(236, 242, 246, 0.56);
        }
      }

      @media (max-width: 640px) {
        .gate-shell {
          padding: 1rem;
        }

        .card {
          padding: 1.35rem 1.1rem 1.2rem;
          border-radius: 1.5rem;
        }

        .gate-kicker-row {
          flex-direction: column;
          align-items: flex-start;
        }

        h1 {
          font-size: 1.8rem;
        }
      }
    </style>
  </body>
</html>
