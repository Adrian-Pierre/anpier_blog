</style>

<script>
	class AboutInteractive extends HTMLElement {
		private cleanupFns: Array<() => void> = [];
		private clockTimer: number | null = null;
		private clockRetryFrame: number | null = null;

		connectedCallback() {
			this.dataset.motion = "on";
			this.setupClock();
			this.setupMotionToggle();

			if (!window.matchMedia("(pointer: fine)").matches) {
				this.setupSwatches();
				return;
			}

			this.setupTiltSurfaces();
			this.setupSwatches();
		}

		disconnectedCallback() {
			this.cleanupFns.forEach((cleanup) => cleanup());
			this.cleanupFns = [];
			if (this.clockTimer !== null) {
				window.clearInterval(this.clockTimer);
				this.clockTimer = null;
			}
			if (this.clockRetryFrame !== null) {
				window.cancelAnimationFrame(this.clockRetryFrame);
				this.clockRetryFrame = null;
			}
		}

		private setupTiltSurfaces() {
			const surfaces = Array.from(this.querySelectorAll<HTMLElement>("[data-tilt-surface]"));

			for (const surface of surfaces) {
				const onMove = (event: PointerEvent) => {
					if (this.dataset.motion === "off") return;

					const rect = surface.getBoundingClientRect();
					const x = ((event.clientX - rect.left) / rect.width) * 100;
					const y = ((event.clientY - rect.top) / rect.height) * 100;
					const rotateY = ((x - 50) / 50) * 2.4;
					const rotateX = ((50 - y) / 50) * 2.1;

					surface.style.setProperty("--about-pointer-x", `${x}%`);
					surface.style.setProperty("--about-pointer-y", `${y}%`);
					surface.style.setProperty("--about-tilt-x", `${rotateX}deg`);
					surface.style.setProperty("--about-tilt-y", `${rotateY}deg`);
					surface.dataset.hovered = "true";
				};

				const reset = () => {
					surface.style.setProperty("--about-tilt-x", "0deg");
					surface.style.setProperty("--about-tilt-y", "0deg");
					surface.dataset.hovered = "false";
				};

				surface.addEventListener("pointermove", onMove);
				surface.addEventListener("pointerleave", reset);

				this.cleanupFns.push(() => {
					surface.removeEventListener("pointermove", onMove);
					surface.removeEventListener("pointerleave", reset);
				});
			}
		}

		private setupClock() {
			const timeElement = this.querySelector<HTMLElement>("[data-about-time]");
			const dateElement = this.querySelector<HTMLElement>("[data-about-date]");
			if (!timeElement || !dateElement) {
				this.clockRetryFrame = window.requestAnimationFrame(() => {
					this.clockRetryFrame = null;
					this.setupClock();
				});
				return;
			}

			if (this.clockRetryFrame !== null) {
				window.cancelAnimationFrame(this.clockRetryFrame);
				this.clockRetryFrame = null;
			}

			if (this.clockTimer !== null) {
				window.clearInterval(this.clockTimer);
				this.clockTimer = null;
			}

			this.updateClock = () => {
				const now = new Date();
				timeElement.textContent = new Intl.DateTimeFormat("en-US", {
					hour: "2-digit",
					minute: "2-digit",
					hour12: false,
				}).format(now);
				dateElement.textContent = new Intl.DateTimeFormat("en-US", {
					month: "short",
					day: "numeric",
					weekday: "short",
				}).format(now);
			};

			this.updateClock();
			this.clockTimer = window.setInterval(() => this.updateClock(), 30_000);
		}

		private updateClock = () => {};

		private setupMotionToggle() {
			const toggle = this.querySelector<HTMLElement>("[data-about-motion-toggle]");
			const label = this.querySelector<HTMLElement>("[data-about-motion-label]");
			if (!toggle || !label) return;

			const updateToggle = (enabled: boolean) => {
				this.dataset.motion = enabled ? "on" : "off";
				toggle.setAttribute("aria-pressed", enabled ? "true" : "false");
				label.textContent = enabled ? "On" : "Off";
				if (!enabled) {
					this.resetTiltSurfaces();
				}
			};

			const onClick = () => {
				updateToggle(this.dataset.motion !== "on");
			};

			updateToggle(true);
			toggle.addEventListener("click", onClick);
			this.cleanupFns.push(() => {
				toggle.removeEventListener("click", onClick);
			});
		}

		private resetTiltSurfaces() {
			const surfaces = Array.from(this.querySelectorAll<HTMLElement>("[data-tilt-surface]"));
			for (const surface of surfaces) {
				surface.style.setProperty("--about-tilt-x", "0deg");
				surface.style.setProperty("--about-tilt-y", "0deg");
				surface.dataset.hovered = "false";
			}
		}

		private setupSwatches() {
			const swatches = Array.from(this.querySelectorAll<HTMLElement>("[data-about-swatch]"));
			const swatchName = this.querySelector<HTMLElement>("[data-about-swatch-name]");

			for (const swatch of swatches) {
				const selectSwatch = () => {
					const accent = swatch.dataset.accent;
					if (!accent) return;

					this.style.setProperty("--about-active-rgb", accent);
					for (const item of swatches) {
						item.setAttribute("aria-pressed", item === swatch ? "true" : "false");
					}
					if (swatchName) {
						swatchName.textContent = swatch.dataset.swatchName || "Current";
					}
				};

				swatch.addEventListener("click", selectSwatch);
				this.cleanupFns.push(() => {
					swatch.removeEventListener("click", selectSwatch);
				});
			}
		}
	}

	if (!customElements.get("about-interactive")) {
		customElements.define("about-interactive", AboutInteractive);
	}
</script>
