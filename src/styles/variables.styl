/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 1.4rem
  --content-delay 140ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: #7dbfaf #9ed6cb
  --page-bg: #f4f1ef #181d24
  --card-bg: rgba(255, 251, 252, 0.8) rgba(28, 33, 41, 0.8)
  --card-border: rgba(255, 255, 255, 0.94) rgba(216, 229, 237, 0.1)

  --btn-content: #658f88 #c8e6df

  --btn-regular-bg: rgba(255, 248, 250, 0.64) rgba(223, 233, 239, 0.07)
  --btn-regular-bg-hover: rgba(255, 252, 253, 0.92) rgba(223, 233, 239, 0.11)
  --btn-regular-bg-active: rgba(246, 238, 241, 0.96) rgba(223, 233, 239, 0.15)

  --btn-plain-bg-hover: rgba(125, 191, 175, 0.1) rgba(158, 214, 203, 0.12)
  --btn-plain-bg-active: rgba(125, 191, 175, 0.16) rgba(158, 214, 203, 0.18)

  --btn-card-bg-hover: rgba(255, 252, 252, 0.94) rgba(223, 233, 239, 0.1)
  --btn-card-bg-active: rgba(245, 239, 240, 0.98) rgba(223, 233, 239, 0.14)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: #47575f #edf2f7

  --title-active: #6aa99e #b7e0d9

  --line-divider: rgba(78, 95, 102, 0.12) rgba(216, 229, 237, 0.1)

  --line-color: rgba(78, 95, 102, 0.15) rgba(216, 229, 237, 0.12)
  --meta-divider: rgba(78, 95, 102, 0.22) rgba(216, 229, 237, 0.22)

  --inline-code-bg: rgba(240, 196, 208, 0.12) rgba(158, 214, 203, 0.12)
  --inline-code-color: #8a6f88 #b7e0d9
  --selection-bg: rgba(125, 191, 175, 0.18) rgba(158, 214, 203, 0.28)
  --codeblock-selection: rgba(125, 191, 175, 0.22) rgba(158, 214, 203, 0.34)
  --codeblock-bg: #faf7f6 #1a2027
  --codeblock-topbar-bg: #f1ecea #232b34
  --codeblock-border: rgba(90, 103, 108, 0.14) rgba(216, 229, 237, 0.1)
  --codeblock-copy-bg: rgba(255, 252, 252, 0.92) rgba(68, 80, 92, 0.9)
  --codeblock-copy-bg-hover: rgba(255, 255, 255, 0.98) rgba(82, 95, 108, 0.94)
  --codeblock-copy-icon: #66757b #eef3f8
  --codeblock-badge-bg: rgba(255, 250, 251, 0.94) rgba(66, 77, 88, 0.9)
  --codeblock-badge-text: #7b8fa7 #c5e5dc
  --codeblock-line-number: rgba(86, 100, 107, 0.28) rgba(216, 229, 237, 0.22)

  --license-block-bg: rgba(125, 191, 175, 0.05) rgba(255, 255, 255, 0.04)

  --link-underline: rgba(125, 191, 175, 0.24) rgba(158, 214, 203, 0.28)
  --link-hover: #7dbfaf #b7e0d9
  --link-active: #8cb6d9 #c7dff0

  --float-panel-bg: rgba(255, 252, 252, 0.86) rgba(24, 30, 37, 0.88)

  --scrollbar-bg-light: black(0.4)
  --scrollbar-bg-hover-light: black(0.5)
  --scrollbar-bg-active-light: black(0.6)

  --scrollbar-bg-dark: white(0.4)
  --scrollbar-bg-hover-dark: white(0.5)
  --scrollbar-bg-active-dark: white(0.6)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.76 0.09 175) oklch(0.78 0.09 175)
  --admonitions-color-note: oklch(0.77 0.08 255) oklch(0.79 0.08 255)
  --admonitions-color-important: oklch(0.78 0.08 330) oklch(0.8 0.08 330)
  --admonitions-color-warning: oklch(0.8 0.08 75) oklch(0.82 0.08 75)
  --admonitions-color-caution: oklch(0.74 0.11 32) oklch(0.76 0.11 32)

  --toc-badge-bg: rgba(125, 191, 175, 0.12) rgba(158, 214, 203, 0.12)
  --toc-btn-hover: rgba(255, 252, 252, 0.9) rgba(255, 255, 255, 0.08)
  --toc-btn-active: rgba(244, 238, 240, 0.95) rgba(255, 255, 255, 0.12)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: rgba(125, 191, 175, 0.15) rgba(158, 214, 203, 0.12)
})
