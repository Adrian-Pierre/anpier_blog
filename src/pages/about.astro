---
import { getEntry, render } from "astro:content";
import { Icon } from "astro-icon/components";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import Markdown from "@components/misc/Markdown.astro";
import { profileConfig } from "../config";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { url } from "../utils/url-utils";

const aboutPost = await getEntry("spec", "about");

if (!aboutPost) {
	throw new Error("About page content not found");
}

const { Content } = await render(aboutPost);

const quickLinks = [
	{
		titleZh: "归档",
		titleEn: "Archive",
		descriptionZh: "查看最近的文章、笔记和项目记录。",
		descriptionEn: "Browse recent posts, notes, and project logs.",
		href: url("/archive/"),
		icon: "material-symbols:library-books-outline-rounded",
		tint: "255 217 227",
	},
	{
		titleZh: "相册",
		titleEn: "Gallery",
		descriptionZh: "收藏一些喜欢的画面和日常片段。",
		descriptionEn: "A small collection of favorite frames and moments.",
		href: url("/pictures/"),
		icon: "material-symbols:imagesmode-outline-rounded",
		tint: "199 233 255",
	},
	{
		titleZh: "友链",
		titleEn: "Friends",
		descriptionZh: "去看看别人的小站和有趣角落。",
		descriptionEn: "Visit other lovely corners of the web.",
		href: url("/friends/"),
		icon: "material-symbols:handshake-outline-rounded",
		tint: "205 239 219",
	},
];

const paletteSwatches = [
	{ nameZh: "薄荷", nameEn: "Mint", value: "rgba(170, 230, 219, 0.9)", accent: "170 230 219" },
	{ nameZh: "蜜桃", nameEn: "Peach", value: "rgba(255, 211, 193, 0.88)", accent: "255 211 193" },
	{ nameZh: "晴空", nameEn: "Sky", value: "rgba(194, 225, 255, 0.92)", accent: "194 225 255" },
	{ nameZh: "紫雾", nameEn: "Lilac", value: "rgba(223, 212, 255, 0.9)", accent: "223 212 255" },
];

const defaultSwatch = paletteSwatches[0];
const aboutDisplayName = profileConfig.name.replace(/\s+/g, " ").trim();
const featuredProject = {
	owner: "Adrian-Pierre",
	repo: "anpier_blog",
	href: "https://github.com/Adrian-Pierre/anpier_blog",
	descriptionZh: "一个基于 Astro 和 Fuwari 重新整理的个人博客，围绕笔记、图片和日常细节慢慢打磨。",
	descriptionEn: "A personal blog rebuilt on Astro and Fuwari, shaped around notes, visuals, and daily refinements.",
	meta: ["Astro", "Fuwari"],
};
---
<MainGridLayout title="关于" description="关于" hideSidebar={true}>
	<about-interactive class="about-page" style={`--about-active-rgb:${defaultSwatch.accent};`}>
		<div
			hidden
			data-lang-document-title-zh={`关于 - ${profileConfig.name}`}
			data-lang-document-title-en={`About - ${profileConfig.name}`}
		></div>
		<section class="about-hero card-base relative overflow-hidden px-6 py-6 md:px-8 md:py-8" data-tilt-surface>
			<div class="about-orb is-pink"></div>
			<div class="about-orb is-mint"></div>
			<div class="about-orb is-blue"></div>

				<div class="about-hero-grid relative z-10">
					<div class="about-portrait-wrap">
						<div class="about-portrait-glow"></div>
						<div class="about-portrait-shell">
						<ImageWrapper
							src={profileConfig.avatar || ""}
							alt={`${profileConfig.name} avatar`}
							class="h-full w-full"
							fit="cover"
								overlay={false}
							/>
						</div>
					</div>

					<div class="about-copy">
						<div class="about-copy-main">
							<p class="about-kicker" data-lang-zh="关于" data-lang-en="About">About</p>
							<h1 class="about-name">{aboutDisplayName}</h1>
							<p class="about-bio">{profileConfig.bio || "A small corner for notes and feelings."}</p>
							<p
								class="about-lead"
								data-lang-zh="这里放着我的技术学习笔记、项目实验记录、日常图片，还有一路上零零散散记下来的想法。"
								data-lang-en="This page gathers my technical study notes, project experiments, daily photos, and a few scattered thoughts along the way."
							>
								This page gathers my technical study notes, project experiments, daily photos, and a few scattered thoughts along the way.
							</p>
						</div>

						<aside class="about-copy-side">
							<section class="about-hero-panel">
								{profileConfig.links.length > 0 && (
									<div class="about-socials is-panel">
										{profileConfig.links.map((item) => (
											<a
												rel="me"
												aria-label={item.name}
												href={item.url}
												target="_blank"
												class="about-social-link"
											>
												<Icon name={item.icon} class="text-[1.15rem]" />
												<span>{item.name}</span>
											</a>
										))}
									</div>
								)}

								<section class="about-widget-card about-widget-card--hero">
									<div class="about-widget-head">
										<p class="about-widget-label" data-lang-zh="本地时间" data-lang-en="Local Time">Local Time</p>
									</div>
									<div class="about-widget-time" data-about-time>--:--</div>
									<p class="about-widget-note" data-about-date>Loading</p>
								</section>

								<div class="about-chip-row is-panel">
									<span class="about-chip is-mint" data-lang-zh="笔记" data-lang-en="Notes">Notes</span>
									<span class="about-chip is-peach" data-lang-zh="图片" data-lang-en="Photos">Photos</span>
									<span class="about-chip is-blue" data-lang-zh="日常" data-lang-en="Daily">Daily</span>
								</div>
							</section>
						</aside>
					</div>
				</div>
			</section>

		<div class="about-lower-grid">
			<section class="card-base about-content-panel relative overflow-hidden px-6 py-6 md:px-7 md:py-7" data-tilt-surface>
				<div class="about-panel-glow is-content"></div>
				<div class="relative z-10">
					<div class="about-section-head">
						<span class="about-section-dot"></span>
						<h2 data-lang-zh="这个小站" data-lang-en="This Corner">This Corner</h2>
					</div>

					<a
						href={featuredProject.href}
						target="_blank"
						rel="noreferrer"
						class="about-project-card"
					>
						<div class="about-project-titlebar">
							<div class="about-project-titlegroup">
								<div class="about-project-avatar">
									<ImageWrapper
										src={profileConfig.avatar || ""}
										alt={`${featuredProject.owner} avatar`}
										class="h-full w-full"
										fit="cover"
										overlay={false}
									/>
								</div>
								<div class="about-project-heading">
									<p>{featuredProject.owner}</p>
									<h3>{featuredProject.repo}</h3>
								</div>
							</div>

							<div class="about-project-github">
								<Icon name="fa6-brands:github" class="text-[1.7rem]" />
							</div>
						</div>

						<p
							class="about-project-description"
							data-lang-zh={featuredProject.descriptionZh}
							data-lang-en={featuredProject.descriptionEn}
						>
							{featuredProject.descriptionEn}
						</p>

						<div class="about-project-meta">
							{featuredProject.meta.map((item) => (
								<span class="about-project-pill">{item}</span>
							))}
						</div>
					</a>

					<Markdown class="about-markdown about-markdown-compact mt-5">
						<Content />
					</Markdown>
				</div>
			</section>

			<aside class="about-side-grid">
				<section class="card-base about-side-card relative overflow-hidden px-6 py-6 md:px-7 md:py-7" data-tilt-surface>
					<div class="about-panel-glow is-links"></div>
					<div class="relative z-10">
						<div class="about-section-head">
							<span class="about-section-dot"></span>
							<h2 data-lang-zh="继续逛逛" data-lang-en="Explore">Explore</h2>
						</div>

						<div class="about-link-list">
							{quickLinks.map((item) => (
								<a
									href={item.href}
									class="about-link-card"
									style={`--about-link-tint: ${item.tint};`}
								>
									<div class="about-link-icon">
										<Icon name={item.icon} class="text-[1.35rem]" />
									</div>
									<div>
										<h3 data-lang-zh={item.titleZh} data-lang-en={item.titleEn}>{item.titleEn}</h3>
										<p data-lang-zh={item.descriptionZh} data-lang-en={item.descriptionEn}>{item.descriptionEn}</p>
									</div>
								</a>
							))}
						</div>

					</div>
				</section>
			</aside>
		</div>

		<section class="card-base about-bottom-controls is-panel">
			<p class="about-bottom-kicker" data-lang-zh="快速设置" data-lang-en="Quick Controls">Quick Controls</p>
			<div class="about-bottom-grid">
				<div class="about-bottom-block is-motion" data-tilt-surface>
					<p class="about-widget-label" data-lang-zh="动态" data-lang-en="Motion">Motion</p>
					<button
						type="button"
						class="about-motion-toggle about-motion-toggle--compact"
						data-about-motion-toggle
						aria-pressed="true"
					>
						<span class="about-motion-switch" aria-hidden="true">
							<span class="about-motion-knob"></span>
						</span>
						<span class="about-motion-text" data-about-motion-label>On</span>
					</button>
					<p class="about-widget-note">Hover Tilt</p>
				</div>

				<div class="about-bottom-block is-palette" data-tilt-surface>
					<p class="about-widget-label" data-lang-zh="色板" data-lang-en="Palette">Palette</p>
					<div class="about-tone-list about-tone-list--compact">
						{paletteSwatches.map((item) => (
							<button
								type="button"
								class="about-tone-button"
								data-about-swatch
								data-accent={item.accent}
								data-swatch-name={item.nameEn}
								data-swatch-name-zh={item.nameZh}
								data-swatch-name-en={item.nameEn}
								aria-pressed={item.nameEn === defaultSwatch.nameEn ? "true" : "false"}
								title={`切换到${item.nameZh}`}
								data-lang-title-zh={`切换到${item.nameZh}`}
								data-lang-title-en={`Switch to ${item.nameEn}`}
							>
								<span class="about-tone-dot" style={`--about-swatch:${item.value};`}></span>
								<span class="sr-only" data-lang-zh={item.nameZh} data-lang-en={item.nameEn}>{item.nameZh}</span>
							</button>
						))}
					</div>
					<p class="about-widget-note" data-about-swatch-name>{defaultSwatch.nameEn}</p>
				</div>
			</div>
		</section>
	</about-interactive>
</MainGridLayout>

<style>
	about-interactive {
		display: block;
	}

	.about-page {
		display: grid;
		gap: 1.6rem;
	}

	about-interactive[data-motion="off"] .about-hero,
	about-interactive[data-motion="off"] .about-content-panel,
	about-interactive[data-motion="off"] .about-side-card,
	about-interactive[data-motion="off"] .about-bottom-block {
		transform: none !important;
	}

	about-interactive[data-motion="off"] .about-hero::after,
	about-interactive[data-motion="off"] .about-content-panel::after,
	about-interactive[data-motion="off"] .about-side-card::after,
	about-interactive[data-motion="off"] .about-bottom-block::after {
		opacity: 0 !important;
	}

	.about-hero,
	.about-content-panel,
	.about-side-card,
	.about-bottom-block {
		position: relative;
		isolation: isolate;
		transform:
			perspective(1600px)
			rotateX(var(--about-tilt-x, 0deg))
			rotateY(var(--about-tilt-y, 0deg));
		transform-style: preserve-3d;
		will-change: transform;
		transition:
			transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 260ms ease;
	}

	.about-hero::after,
	.about-content-panel::after,
	.about-side-card::after,
	.about-bottom-block::after {
		content: "";
		position: absolute;
		inset: -35%;
		background:
			radial-gradient(
				circle at var(--about-pointer-x, 50%) var(--about-pointer-y, 50%),
				rgba(var(--about-active-rgb, 170 230 219), 0.18),
				rgba(255, 255, 255, 0) 24rem
			);
		opacity: var(--about-surface-glow, 0);
		pointer-events: none;
		transition: opacity 220ms ease;
		z-index: 0;
	}

	.about-hero[data-hovered="true"],
	.about-content-panel[data-hovered="true"],
	.about-side-card[data-hovered="true"],
	.about-bottom-block[data-hovered="true"] {
		--about-surface-glow: 1;
		box-shadow: 0 34px 78px -48px rgba(24, 51, 56, 0.28);
	}

	.about-hero {
		background:
			radial-gradient(circle at 78% 18%, rgba(var(--about-active-rgb, 170 230 219), 0.28), transparent 16rem),
			linear-gradient(140deg, rgba(255, 255, 255, 0.9), rgba(251, 245, 255, 0.82) 34%, rgba(241, 252, 248, 0.82) 68%, rgba(239, 247, 255, 0.88)),
			rgba(255, 255, 255, 0.72);
		box-shadow: 0 36px 76px -50px rgba(24, 51, 56, 0.28);
	}

	.about-hero-grid {
		display: grid;
		gap: 2rem;
		align-items: start;
		grid-template-columns: minmax(0, 15.75rem) minmax(0, 1fr);
	}

	.about-orb {
		position: absolute;
		border-radius: 999px;
		filter: blur(10px);
		opacity: 0.8;
		pointer-events: none;
	}

	.about-orb.is-pink {
		top: -2.5rem;
		left: -1rem;
		width: 12rem;
		height: 12rem;
		background: radial-gradient(circle, rgba(255, 207, 223, 0.75), rgba(255, 207, 223, 0));
	}

	.about-orb.is-mint {
		right: 10%;
		top: 2rem;
		width: 10rem;
		height: 10rem;
		background: radial-gradient(circle, rgba(179, 237, 226, 0.68), rgba(179, 237, 226, 0));
	}

	.about-orb.is-blue {
		right: -1.5rem;
		bottom: -2rem;
		width: 12rem;
		height: 12rem;
		background: radial-gradient(circle, rgba(198, 227, 255, 0.75), rgba(198, 227, 255, 0));
	}

	.about-portrait-wrap {
		position: relative;
		padding-top: 0.35rem;
	}

	.about-portrait-glow {
		position: absolute;
		inset: 1.2rem;
		border-radius: 2rem;
		background: linear-gradient(145deg, rgba(255, 214, 228, 0.58), rgba(183, 230, 221, 0.42));
		filter: blur(16px);
		opacity: 0.9;
	}

	.about-portrait-shell {
		position: relative;
		overflow: hidden;
		aspect-ratio: 1 / 1.12;
		border-radius: 1.85rem;
		padding: 0.68rem;
		border: 1px solid rgba(255, 255, 255, 0.92);
		background:
			linear-gradient(160deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.28)),
			linear-gradient(135deg, rgba(255, 211, 223, 0.4), rgba(194, 230, 255, 0.32));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.9),
			0 28px 56px -42px rgba(24, 51, 56, 0.34);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.about-portrait-shell :global(img) {
		border-radius: 1.3rem;
	}

	.about-copy {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(15rem, 17rem);
		gap: 1.35rem;
		align-items: start;
	}

	.about-copy-main {
		min-width: 0;
		padding-top: 0.25rem;
	}

	.about-copy-side {
		min-width: 0;
	}

	.about-hero-panel {
		display: grid;
		gap: 0.85rem;
		padding: 1rem;
		border-radius: 1.45rem;
		border: 1px solid rgba(255, 255, 255, 0.86);
		background:
			linear-gradient(160deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.4)),
			rgba(255, 255, 255, 0.5);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.88),
			0 24px 48px -38px rgba(24, 51, 56, 0.22);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
	}

	.about-chip-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.about-chip-row.is-panel {
		margin-top: 0.1rem;
	}

	.about-chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.42rem 0.8rem;
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		border: 1px solid rgba(255, 255, 255, 0.72);
		box-shadow: 0 14px 28px -22px rgba(24, 51, 56, 0.16);
	}

	.about-chip.is-mint {
		background: rgba(221, 247, 240, 0.88);
		color: #4e857e;
	}

	.about-chip.is-peach {
		background: rgba(255, 233, 223, 0.9);
		color: #a86f5e;
	}

	.about-chip.is-blue {
		background: rgba(225, 239, 255, 0.9);
		color: #5c7d9b;
	}

	.about-kicker {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: rgba(82, 103, 114, 0.82);
	}

	.about-name {
		margin: 0.75rem 0 0;
		font-size: clamp(2.8rem, 4.8vw, 4.15rem);
		line-height: 0.96;
		font-weight: 900;
		letter-spacing: 0.03em;
		color: rgb(73 85 93);
		text-wrap: balance;
		text-shadow:
			0 1px 0 rgba(255, 255, 255, 0.84),
			0 12px 24px rgba(177, 197, 223, 0.08);
		-webkit-text-stroke: 0.01em rgba(73, 85, 93, 0.02);
	}

	.about-bio {
		display: inline-flex;
		align-items: center;
		margin: 1rem 0 0;
		padding: 0.36rem 0.7rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.78);
		background: rgba(255, 255, 255, 0.52);
		font-size: 0.78rem;
		line-height: 1;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(73, 93, 100, 0.78);
		box-shadow: 0 14px 28px -24px rgba(24, 51, 56, 0.18);
	}

	.about-lead {
		margin: 1.15rem 0 0;
		max-width: 34rem;
		font-size: 1rem;
		line-height: 1.9;
		color: rgba(51, 79, 82, 0.68);
	}

	.about-socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0;
	}

	.about-socials.is-panel {
		display: grid;
		gap: 0.65rem;
	}

	.about-social-link {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.75rem 1rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.84);
		background: rgba(255, 255, 255, 0.68);
		color: var(--deep-text);
		font-size: 0.95rem;
		font-weight: 600;
		box-shadow: 0 18px 40px -32px rgba(24, 51, 56, 0.24);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		transition:
			transform 0.22s ease,
			background-color 0.22s ease,
			border-color 0.22s ease,
			box-shadow 0.22s ease;
	}

	.about-socials.is-panel .about-social-link {
		width: 100%;
		justify-content: center;
		padding: 0.72rem 0.95rem;
		border-radius: 1rem;
	}

	.about-social-link:hover {
		transform: translateY(-2px);
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 24px 48px -34px rgba(24, 51, 56, 0.28);
	}

	.about-widget-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
		margin-top: 1.5rem;
	}

	.about-widget-grid.is-compact {
		grid-template-columns: minmax(0, 1fr);
		max-width: 17rem;
	}

	.about-widget-card {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 9rem;
		padding: 1rem 1.05rem;
		border-radius: 1.25rem;
		border: 1px solid rgba(255, 255, 255, 0.84);
		background:
			linear-gradient(145deg, rgba(var(--about-active-rgb, 170 230 219), 0.16), rgba(255, 255, 255, 0.26) 52%, rgba(255, 255, 255, 0) 100%),
			linear-gradient(160deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.42)),
			rgba(255, 255, 255, 0.5);
		box-shadow: 0 24px 48px -38px rgba(24, 51, 56, 0.24);
	}

	.about-widget-card--hero {
		min-height: auto;
		padding: 0.9rem 0.95rem;
		border-radius: 1.2rem;
		background:
			linear-gradient(145deg, rgba(var(--about-active-rgb, 170 230 219), 0.12), rgba(255, 255, 255, 0.18) 52%, rgba(255, 255, 255, 0) 100%),
			linear-gradient(160deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.4)),
			rgba(255, 255, 255, 0.46);
	}

	.about-widget-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.about-widget-label {
		margin: 0;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
