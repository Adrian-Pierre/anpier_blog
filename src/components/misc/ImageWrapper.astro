---
import path from "node:path";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	fit?: "cover" | "contain";
	overlay?: boolean;
	proxyExternal?: boolean;
}

import { Image } from "astro:assets";
import { url } from "../../utils/url-utils";

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	fit = "cover",
	overlay = true,
	proxyExternal = false,
} = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");
const shouldProxyExternal =
	proxyExternal &&
	!import.meta.env.DEV &&
	(src.startsWith("http://") || src.startsWith("https://"));

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
// biome-ignore lint/suspicious/noImplicitAnyLet: <check later>
let img;
if (isLocal) {
	const files = import.meta.glob<ImageMetadata>("../../**", {
		import: "default",
	});
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	}
	img = await file();
}

const imageClass = `w-full h-full ${fit === "contain" ? "object-contain" : "object-cover"}`;
const imageStyle = `object-position: ${position}`;
const remoteImageSrc = shouldProxyExternal
	? `${url("/api/image-proxy/")}?url=${encodeURIComponent(src)}`
	: isPublic
		? url(src)
		: src;
---
<div id={id} class:list={[className, 'overflow-hidden relative']}>
    {overlay && <div class="transition absolute inset-0 dark:bg-black/10 bg-opacity-50 pointer-events-none"></div>}
    {isLocal && img && <Image src={img} alt={alt || ""} class={imageClass} style={imageStyle}/>}
    {!isLocal && <img src={remoteImageSrc} alt={alt || ""} class={imageClass} style={imageStyle}/>}
</div>
