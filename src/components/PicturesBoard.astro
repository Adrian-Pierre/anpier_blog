---
import type { PictureItem } from "@/data/pictures";
import ImageWrapper from "./misc/ImageWrapper.astro";

interface Props {
	entries: PictureItem[];
}

const { entries } = Astro.props;

const fallbackPositions = [
	{ x: 6, y: 12, rotate: -8, width: 240 },
	{ x: 28, y: 4, rotate: 6, width: 220 },
	{ x: 54, y: 11, rotate: -4, width: 250 },
	{ x: 73, y: 22, rotate: 9, width: 210 },
	{ x: 16, y: 48, rotate: 5, width: 230 },
	{ x: 41, y: 56, rotate: -7, width: 220 },
	{ x: 66, y: 52, rotate: 4, width: 240 },
	{ x: 79, y: 6, rotate: -10, width: 200 },
];
const rotationOffsets = [-1.6, 1.2, -2.1, 1.7, -1.3, 2.2, -1.8, 1.5];
const occupiedPositions = new Map<string, number>();

const pictures = entries.map((entry, index) => {
	const fallback = fallbackPositions[index % fallbackPositions.length];
	const rotationOffset = rotationOffsets[index % rotationOffsets.length];
	const baseRotate = entry.rotate ?? fallback.rotate;
	const baseMagnitude = Math.max(Math.abs(baseRotate), 3);
	const direction = index % 2 === 0 ? -1 : 1;
	const requestedX = entry.x ?? fallback.x;
	const requestedY = entry.y ?? fallback.y;
	const positionKey = `${requestedX.toFixed(2)}:${requestedY.toFixed(2)}`;
	const duplicateCount = occupiedPositions.get(positionKey) ?? 0;
	occupiedPositions.set(positionKey, duplicateCount + 1);
	const resolvedPosition = duplicateCount === 0 ? { x: requestedX, y: requestedY } : fallback;

	return {
		...entry,
		index,
		title: entry.title || `图片 ${index + 1}`,
		description: entry.description || "",
		x: resolvedPosition.x,
		y: resolvedPosition.y,
		rotate: direction * baseMagnitude + rotationOffset,
		width: entry.width ?? fallback.width,
		fit: entry.fit ?? "contain",
	};
});
---

<pictures-board class="block w-full" data-ready="false">
	<div class="board-shell relative overflow-hidden rounded-[1.6rem] border border-[var(--line-divider)] p-3 backdrop-blur-sm dark:bg-white/[0.03] md:p-4">
		<div class="pointer-events-none absolute inset-0 opacity-35 [background-image:linear-gradient(to_right,rgba(255,255,255,0.22)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.22)_1px,transparent_1px)] [background-size:24px_24px]"></div>
		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(120,168,158,0.12),transparent_32rem),radial-gradient(circle_at_bottom_right,rgba(241,248,246,0.72),transparent_26rem)] dark:bg-[radial-gradient(circle_at_top_left,rgba(88,135,126,0.18),transparent_30rem),radial-gradient(circle_at_bottom_right,rgba(34,53,50,0.28),transparent_22rem)]"></div>

		<div class="board-stage relative h-[34rem] overflow-hidden rounded-[1.3rem] md:h-[40rem]" data-stage>
			{pictures.map((picture) => (
				<article
					class="picture-card absolute overflow-hidden border border-black/5 bg-[rgba(255,255,255,0.92)] shadow-[0_24px_50px_-30px_rgba(24,51,56,0.38)] outline-none transition-[box-shadow,border-color,transform] duration-300 ease-out dark:border-white/20 dark:bg-[rgba(226,236,234,0.26)]"
					data-picture-card
					data-index={String(picture.index)}
					data-x={String(picture.x)}
					data-y={String(picture.y)}
					draggable="false"
					style={`--picture-width:${picture.width}px; --picture-rotate:${picture.rotate}deg; animation-delay: calc(var(--content-delay) + ${picture.index * 45}ms);`}
				>
					<div class="picture-card-frame h-full w-full">
						<ImageWrapper
							src={picture.image}
							alt={picture.title}
							class="picture-media h-full w-full pointer-events-none select-none"
							fit={picture.fit}
							overlay={false}
						/>
					</div>
				</article>
			))}
		</div>
	</div>
</pictures-board>

<style>
	pictures-board {
		display: block;
	}

	.board-shell {
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(243, 248, 247, 0.78));
		box-shadow: 0 34px 76px -48px rgba(24, 51, 56, 0.3);
		transition:
			opacity var(--page-transition-duration-fast) var(--page-transition-easing),
			transform var(--page-transition-duration) var(--page-transition-easing);
	}

	pictures-board[data-ready="false"] .board-shell {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transform: translateY(var(--page-transition-distance));
	}

	pictures-board[data-ready="true"] .board-shell {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.picture-card {
		--picture-corner: 1.08rem;
		width: min(calc(var(--picture-width) * 0.82), 30vw);
		aspect-ratio: var(--picture-ratio, 4 / 5);
		border-radius: var(--picture-corner);
		box-sizing: border-box;
		cursor: grab;
		touch-action: none;
		user-select: none;
		-webkit-user-select: none;
		will-change: transform, box-shadow;
		transform:
			translateY(calc(var(--picture-entry-offset, 0px) + var(--picture-lift, 0px)))
			rotate(var(--picture-rotate, 0deg))
			scale(var(--picture-scale, 1));
		transition:
			opacity var(--page-transition-duration-fast) var(--page-transition-easing),
			transform var(--page-transition-duration-slow) var(--page-transition-easing),
			box-shadow 240ms ease,
			border-color 240ms ease;
	}

	pictures-board[data-ready="false"] .picture-card {
		opacity: 0;
		pointer-events: none;
		--picture-entry-offset: var(--page-transition-distance);
	}

	pictures-board[data-ready="true"] .picture-card {
		opacity: 1;
		--picture-entry-offset: 0px;
	}

	.picture-card:active {
		cursor: grabbing;
	}

	.picture-card:hover,
	.picture-card:focus-visible {
		--picture-lift: -8px;
		--picture-scale: 1.035;
	}

	.picture-card-frame {
		border-radius: inherit;
		overflow: hidden;
	}

	.picture-media {
		border-radius: inherit;
	}

	:global(:root.dark) .picture-card {
		background: rgba(226, 236, 234, 0.26);
		border-color: rgba(228, 239, 236, 0.24);
		box-shadow: 0 20px 46px -30px rgba(5, 12, 18, 0.44);
	}

	:global(:root.dark) .picture-card-frame {
		background: rgba(255, 255, 255, 0.02);
	}

	@media (max-width: 900px) {
		.picture-card {
			width: min(calc(var(--picture-width) * 0.84), 38vw);
		}
	}

	@media (max-width: 640px) {
		.board-shell {
			padding: 0.7rem;
			border-radius: 1.3rem;
		}

		.board-stage {
			height: 28rem;
			border-radius: 1rem;
		}

		.picture-card {
			width: min(calc(var(--picture-width) * 0.68), 38vw);
			--picture-corner: 0.88rem;
		}
	}
</style>

<script>
	class PicturesBoard extends HTMLElement {
		private stage: HTMLElement | null = null;
		private cards: HTMLElement[] = [];
		private resizeObserver: ResizeObserver | null = null;
		private nextZIndex = 20;

		connectedCallback() {
			this.stage = this.querySelector("[data-stage]");
			this.cards = Array.from(this.querySelectorAll("[data-picture-card]"));
			this.dataset.ready = "false";

			if (!(this.stage instanceof HTMLElement) || this.cards.length === 0) {
				return;
			}

			window.requestAnimationFrame(() => {
				this.syncAllCardRatios();
				this.layoutCards();
				this.clampCards();
				this.dataset.ready = "true";
			});

			this.cards.forEach((card) => this.bindCard(card));
			this.resizeObserver = new ResizeObserver(() => this.clampCards());
			this.resizeObserver.observe(this.stage);
		}

		disconnectedCallback() {
			this.resizeObserver?.disconnect();
		}

		private syncAllCardRatios() {
			for (const card of this.cards) {
				this.syncCardRatio(card);
			}
		}

		private syncCardRatio(card: HTMLElement) {
			const image = card.querySelector("img");
			if (!(image instanceof HTMLImageElement)) return;

			const applyRatio = () => {
				if (!image.naturalWidth || !image.naturalHeight) return;

				card.style.setProperty(
					"--picture-ratio",
					`${image.naturalWidth} / ${image.naturalHeight}`,
				);
				this.clampCards();
			};

			if (image.complete) {
				applyRatio();
				return;
			}

			image.addEventListener("load", applyRatio, { once: true });
		}

		private layoutCards() {
			if (!(this.stage instanceof HTMLElement)) return;

			const stageWidth = this.stage.clientWidth;
			const stageHeight = this.stage.clientHeight;

			for (const card of this.cards) {
				const x = Number(card.dataset.x || 0);
				const y = Number(card.dataset.y || 0);
				const width = card.offsetWidth;
				const height = card.offsetHeight;
				const maxLeft = Math.max(stageWidth - width, 0);
				const maxTop = Math.max(stageHeight - height, 0);

				card.style.left = `${(maxLeft * x) / 100}px`;
				card.style.top = `${(maxTop * y) / 100}px`;
				card.style.zIndex = String(this.nextZIndex++);
			}
		}

		private clampCards() {
			if (!(this.stage instanceof HTMLElement)) return;

			const stageWidth = this.stage.clientWidth;
			const stageHeight = this.stage.clientHeight;

			for (const card of this.cards) {
				const maxLeft = Math.max(stageWidth - card.offsetWidth, 0);
				const maxTop = Math.max(stageHeight - card.offsetHeight, 0);
				const left = Number.parseFloat(card.style.left || "0");
				const top = Number.parseFloat(card.style.top || "0");

				card.style.left = `${this.clamp(left, 0, maxLeft)}px`;
				card.style.top = `${this.clamp(top, 0, maxTop)}px`;
			}
		}

		private bindCard(card: HTMLElement) {
			let pointerId = -1;
			let startX = 0;
			let startY = 0;
			let initialLeft = 0;
			let initialTop = 0;
			let moved = false;
			const bringToFront = () => {
				card.style.zIndex = String(this.nextZIndex++);
			};

			const onPointerMove = (event: PointerEvent) => {
				if (!(this.stage instanceof HTMLElement) || event.pointerId !== pointerId) return;

				const deltaX = event.clientX - startX;
				const deltaY = event.clientY - startY;

				moved = moved || Math.abs(deltaX) > 4 || Math.abs(deltaY) > 4;

				const maxLeft = Math.max(this.stage.clientWidth - card.offsetWidth, 0);
				const maxTop = Math.max(this.stage.clientHeight - card.offsetHeight, 0);

				card.style.left = `${this.clamp(initialLeft + deltaX, 0, maxLeft)}px`;
				card.style.top = `${this.clamp(initialTop + deltaY, 0, maxTop)}px`;
			};

			const finishPointer = (event: PointerEvent) => {
				if (event.pointerId !== pointerId) return;

				card.releasePointerCapture(pointerId);
				card.removeEventListener("pointermove", onPointerMove);
				card.removeEventListener("pointerup", finishPointer);
				card.removeEventListener("pointercancel", finishPointer);

				pointerId = -1;
			};

			card.addEventListener("pointerdown", (event: PointerEvent) => {
				if (!(this.stage instanceof HTMLElement)) return;

				event.preventDefault();
				pointerId = event.pointerId;
				startX = event.clientX;
				startY = event.clientY;
				initialLeft = Number.parseFloat(card.style.left || "0");
				initialTop = Number.parseFloat(card.style.top || "0");
				moved = false;

				card.style.zIndex = String(this.nextZIndex++);
				card.setPointerCapture(pointerId);
				card.addEventListener("pointermove", onPointerMove);
				card.addEventListener("pointerup", finishPointer);
				card.addEventListener("pointercancel", finishPointer);
			});

			card.addEventListener("dragstart", (event: DragEvent) => {
				event.preventDefault();
			});
			card.addEventListener("pointerenter", bringToFront);
		}

		private clamp(value: number, min: number, max: number) {
			return Math.min(Math.max(value, min), max);
		}
	}

	if (!customElements.get("pictures-board")) {
		customElements.define("pictures-board", PicturesBoard);
	}
</script>
