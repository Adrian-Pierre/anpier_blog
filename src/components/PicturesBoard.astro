---
import type { PictureItem } from "@/data/pictures";
import ImageWrapper from "./misc/ImageWrapper.astro";

interface Props {
	entries: PictureItem[];
}

const { entries } = Astro.props;

const fallbackPositions = [
	{ x: 6, y: 12, rotate: -8, width: 240 },
	{ x: 28, y: 4, rotate: 6, width: 220 },
	{ x: 54, y: 11, rotate: -4, width: 250 },
	{ x: 73, y: 22, rotate: 9, width: 210 },
	{ x: 16, y: 48, rotate: 5, width: 230 },
	{ x: 41, y: 56, rotate: -7, width: 220 },
	{ x: 66, y: 52, rotate: 4, width: 240 },
	{ x: 79, y: 6, rotate: -10, width: 200 },
];
const rotationOffsets = [-1.6, 1.2, -2.1, 1.7, -1.3, 2.2, -1.8, 1.5];
const occupiedPositions = new Map<string, number>();

const pictures = entries.map((entry, index) => {
	const fallback = fallbackPositions[index % fallbackPositions.length];
	const rotationOffset = rotationOffsets[index % rotationOffsets.length];
	const baseRotate = entry.rotate ?? fallback.rotate;
	const baseMagnitude = Math.max(Math.abs(baseRotate), 3);
	const direction = index % 2 === 0 ? -1 : 1;
	const requestedX = entry.x ?? fallback.x;
	const requestedY = entry.y ?? fallback.y;
	const positionKey = `${requestedX.toFixed(2)}:${requestedY.toFixed(2)}`;
	const duplicateCount = occupiedPositions.get(positionKey) ?? 0;
	occupiedPositions.set(positionKey, duplicateCount + 1);
	const resolvedPosition = duplicateCount === 0 ? { x: requestedX, y: requestedY } : fallback;

	return {
		...entry,
		index,
		title: entry.title || `图片 ${index + 1}`,
		description: entry.description || "",
		x: resolvedPosition.x,
		y: resolvedPosition.y,
		rotate: direction * baseMagnitude + rotationOffset,
		width: entry.width ?? fallback.width,
		fit: entry.fit ?? "contain",
	};
});
---

<pictures-board class="block w-full" data-ready="false">
	<div class="board-shell relative overflow-hidden rounded-[1.6rem] border border-[var(--line-divider)] p-3 backdrop-blur-sm dark:bg-white/[0.03] md:p-4" data-board-shell data-parallax="idle">
		<div class="board-parallax-layer board-parallax-layer--grid"></div>
		<div class="board-parallax-layer board-parallax-layer--glow"></div>
		<div class="board-parallax-layer board-parallax-layer--veil"></div>

		<div class="board-stage relative h-[34rem] overflow-hidden rounded-[1.3rem] md:h-[40rem]" data-stage>
			{pictures.map((picture) => (
				<article
					class="picture-card absolute overflow-hidden border border-black/5 bg-[rgba(255,255,255,0.92)] shadow-[0_24px_50px_-30px_rgba(24,51,56,0.38)] outline-none transition-[box-shadow,border-color,transform] duration-300 ease-out dark:border-white/20 dark:bg-[rgba(226,236,234,0.26)]"
					data-picture-card
					data-index={String(picture.index)}
					data-x={String(picture.x)}
					data-y={String(picture.y)}
					data-description={picture.description}
					data-title={picture.title}
					data-selected="false"
					tabindex="0"
					aria-label={`${picture.title}. ${picture.description}`}
					draggable="false"
					style={`--picture-width:${picture.width}px; --picture-rotate:${picture.rotate}deg; animation-delay: calc(var(--content-delay) + ${picture.index * 45}ms);`}
				>
					<div class="picture-card-frame h-full w-full">
						<ImageWrapper
							src={picture.image}
							alt={picture.title}
							class="picture-media h-full w-full pointer-events-none select-none"
							fit={picture.fit}
							overlay={false}
						/>
					</div>
				</article>
			))}
		</div>
	</div>

	<div class="picture-info-panel" data-picture-info data-active="false" aria-live="polite">
		<p class="picture-info-text" data-picture-info-text></p>
	</div>
</pictures-board>

<style>
	pictures-board {
		display: block;
		padding-bottom: calc(7.8rem + env(safe-area-inset-bottom, 0px));
	}

	.board-shell {
		--board-shift-x: 0px;
		--board-shift-y: 0px;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(243, 248, 247, 0.78));
		box-shadow: 0 34px 76px -48px rgba(24, 51, 56, 0.3);
		transition:
			opacity var(--page-transition-duration-fast) var(--page-transition-easing),
			transform var(--page-transition-duration) var(--page-transition-easing);
	}

	.board-parallax-layer {
		position: absolute;
		pointer-events: none;
		will-change: transform;
		transition:
			transform 260ms var(--page-transition-easing),
			opacity 240ms ease;
	}

	.board-parallax-layer--grid {
		inset: 0;
		opacity: 0.34;
		background-image:
			linear-gradient(to right, rgba(255, 255, 255, 0.24) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(255, 255, 255, 0.24) 1px, transparent 1px);
		background-size: 24px 24px;
		transform: translate3d(calc(var(--board-shift-x) * -0.28), calc(var(--board-shift-y) * -0.28), 0);
	}

	.board-parallax-layer--glow {
		inset: -8%;
		opacity: 0.92;
		background:
			radial-gradient(circle at top left, rgba(120, 168, 158, 0.16), transparent 32rem),
			radial-gradient(circle at bottom right, rgba(241, 248, 246, 0.84), transparent 26rem),
			radial-gradient(circle at 84% 18%, rgba(194, 225, 255, 0.22), transparent 20rem);
		transform: translate3d(calc(var(--board-shift-x) * 0.72), calc(var(--board-shift-y) * 0.72), 0);
	}

	.board-parallax-layer--veil {
		inset: 0;
		opacity: 0.58;
		background:
			linear-gradient(140deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0) 42%),
			radial-gradient(circle at 20% 14%, rgba(255, 218, 229, 0.18), transparent 24rem);
		transform: translate3d(calc(var(--board-shift-x) * -0.16), calc(var(--board-shift-y) * -0.16), 0);
	}

	.board-shell[data-parallax="active"] .board-parallax-layer--glow {
		opacity: 1;
	}

	pictures-board[data-ready="false"] .board-shell {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transform: translateY(var(--page-transition-distance));
	}

	pictures-board[data-ready="true"] .board-shell {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.picture-card {
		--picture-corner: 1.08rem;
		width: min(calc(var(--picture-width) * 0.78), 28vw);
		aspect-ratio: var(--picture-ratio, 4 / 5);
		border-radius: var(--picture-corner);
		box-sizing: border-box;
		cursor: grab;
		touch-action: none;
		user-select: none;
		-webkit-user-select: none;
		will-change: transform, box-shadow;
		transform:
			translateY(calc(var(--picture-entry-offset, 0px) + var(--picture-lift, 0px)))
			rotate(var(--picture-rotate, 0deg))
			scale(var(--picture-scale, 1));
		transition:
			opacity var(--page-transition-duration-fast) var(--page-transition-easing),
			transform var(--page-transition-duration-slow) var(--page-transition-easing),
			box-shadow 240ms ease,
			border-color 240ms ease;
	}

	pictures-board[data-ready="false"] .picture-card {
		opacity: 0;
		pointer-events: none;
		--picture-entry-offset: var(--page-transition-distance);
	}

	pictures-board[data-ready="true"] .picture-card {
		opacity: 1;
		--picture-entry-offset: 0px;
	}

	.picture-card:active {
		cursor: grabbing;
	}

	.picture-card:hover,
	.picture-card:focus-visible {
		--picture-lift: -8px;
		--picture-scale: 1.035;
	}

	.picture-card[data-dragging="true"] {
		--picture-lift: -4px;
		--picture-scale: 1.024;
		box-shadow: 0 28px 52px -30px rgba(24, 51, 56, 0.34);
		cursor: grabbing;
	}

	.picture-card[data-selected="true"] {
		--picture-lift: -8px;
		--picture-scale: 1.03;
		border-color: rgba(125, 191, 175, 0.26);
		box-shadow:
			0 28px 54px -30px rgba(24, 51, 56, 0.26),
			0 0 0 0.14rem rgba(125, 191, 175, 0.14);
	}

	.picture-card-frame {
		position: relative;
		border-radius: inherit;
		overflow: hidden;
	}

	.picture-card:hover .picture-media,
	.picture-card:focus-visible .picture-media {
		transform: scale(1.02);
		filter: saturate(0.94) brightness(0.88);
	}

	.picture-info-panel {
		position: fixed;
		left: 50%;
		bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
		z-index: 80;
		display: flex;
		align-items: center;
		justify-content: center;
		width: min(calc(100vw - 2.2rem), 46rem);
		min-height: 0;
		padding: 0.9rem 1.15rem 0.92rem;
		border-radius: 1.45rem;
		border: 1px solid rgba(255, 255, 255, 0.78);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(247, 250, 249, 0.72)),
			linear-gradient(135deg, rgba(255, 220, 229, 0.16), rgba(189, 229, 255, 0.08)),
			rgba(255, 255, 255, 0.72);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.92),
			0 20px 40px -24px rgba(24, 51, 56, 0.16),
			0 8px 18px -16px rgba(24, 51, 56, 0.1);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		overflow: hidden;
		opacity: 0;
		pointer-events: none;
		transform: translateX(-50%) translateY(0.7rem) scale(0.985);
		transition:
			opacity 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease,
			transform 260ms var(--page-transition-easing);
	}

	.picture-info-panel::before {
		content: "";
		position: absolute;
		inset: 0 auto auto 1.05rem;
		width: 3.4rem;
		height: 2px;
		border-radius: 999px;
		background: linear-gradient(90deg, rgba(255, 208, 221, 0.9), rgba(var(--about-active-rgb, 170 230 219), 0.9));
		opacity: 0.86;
	}

	.picture-info-panel[data-active="true"] {
		opacity: 1;
		border-color: rgba(var(--about-active-rgb, 170 230 219), 0.16);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.94),
			0 22px 44px -22px rgba(24, 51, 56, 0.18),
			0 10px 22px -18px rgba(24, 51, 56, 0.12);
		transform: translateX(-50%) translateY(0) scale(1);
	}

	.picture-info-text {
		margin: 0;
		width: 100%;
		min-height: 1.55em;
		padding-top: 0.1rem;
		font-size: 0.88rem;
		line-height: 1.7;
		color: rgba(67, 82, 89, 0.88);
		text-align: center;
		letter-spacing: 0.01em;
		text-wrap: pretty;
	}

	.picture-media {
		border-radius: inherit;
		transition:
			transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 260ms ease;
	}

	:global(:root.dark) .picture-card {
		background: rgba(226, 236, 234, 0.26);
		border-color: rgba(228, 239, 236, 0.24);
		box-shadow: 0 20px 46px -30px rgba(5, 12, 18, 0.44);
	}

	:global(:root.dark) .board-parallax-layer--grid {
		opacity: 0.16;
		background-image:
			linear-gradient(to right, rgba(255, 255, 255, 0.1) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
	}

	:global(:root.dark) .board-parallax-layer--glow {
		background:
			radial-gradient(circle at top left, rgba(88, 135, 126, 0.22), transparent 30rem),
			radial-gradient(circle at bottom right, rgba(34, 53, 50, 0.32), transparent 22rem),
			radial-gradient(circle at 84% 18%, rgba(124, 153, 183, 0.16), transparent 18rem);
	}

	:global(:root.dark) .board-parallax-layer--veil {
		background:
			linear-gradient(140deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0) 42%),
			radial-gradient(circle at 20% 14%, rgba(214, 171, 191, 0.08), transparent 22rem);
	}

	:global(:root.dark) .picture-card-frame {
		background: rgba(255, 255, 255, 0.02);
	}

	:global(:root.dark) .picture-card[data-selected="true"] {
		border-color: rgba(158, 214, 203, 0.24);
		box-shadow:
			0 24px 46px -28px rgba(5, 12, 18, 0.42),
			0 0 0 0.12rem rgba(158, 214, 203, 0.16);
	}

	:global(:root.dark) .picture-info-panel {
		background:
			linear-gradient(180deg, rgba(36, 43, 51, 0.92), rgba(27, 33, 41, 0.84)),
			linear-gradient(135deg, rgba(221, 171, 194, 0.08), rgba(158, 214, 203, 0.05)),
			rgba(22, 27, 34, 0.82);
		border-color: rgba(228, 239, 236, 0.1);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.05),
			0 22px 42px -24px rgba(5, 12, 18, 0.38),
			0 8px 18px -16px rgba(5, 12, 18, 0.28);
	}

	:global(:root.dark) .picture-info-panel::before {
		background: linear-gradient(90deg, rgba(230, 184, 202, 0.78), rgba(158, 214, 203, 0.76));
	}

	:global(:root.dark) .picture-info-panel[data-active="true"] {
		border-color: rgba(158, 214, 203, 0.14);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.06),
			0 24px 46px -22px rgba(5, 12, 18, 0.42),
			0 10px 20px -16px rgba(5, 12, 18, 0.3);
	}

	:global(:root.dark) .picture-info-text {
		color: rgba(238, 243, 246, 0.86);
	}

	@media (max-width: 900px) {
		.picture-card {
			width: min(calc(var(--picture-width) * 0.72), 36vw);
		}
	}

	@media (max-width: 640px) {
		pictures-board {
			padding-bottom: calc(7rem + env(safe-area-inset-bottom, 0px));
		}

		.board-shell {
			padding: 0.7rem;
			border-radius: 1.3rem;
		}

		.board-stage {
			height: 28rem;
			border-radius: 1rem;
		}

		.picture-card {
			width: min(calc(var(--picture-width) * 0.6), 34vw);
			--picture-corner: 0.88rem;
		}

		.picture-info-panel {
			left: 50%;
			bottom: calc(0.8rem + env(safe-area-inset-bottom, 0px));
			width: min(calc(100vw - 1rem), 46rem);
			padding: 0.82rem 0.88rem 0.84rem;
			border-radius: 1.15rem;
		}

		.picture-info-panel::before {
			left: 0.88rem;
			width: 2.6rem;
		}

		.picture-info-text {
			font-size: 0.76rem;
			line-height: 1.55;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.board-parallax-layer,
		.picture-card,
		.picture-media,
		.picture-info-panel {
			transition: none !important;
		}
	}
</style>

<script>
	class PicturesBoard extends HTMLElement {
		private stage: HTMLElement | null = null;
		private shell: HTMLElement | null = null;
		private cards: HTMLElement[] = [];
		private infoPanel: HTMLElement | null = null;
		private infoText: HTMLElement | null = null;
		private resizeObserver: ResizeObserver | null = null;
		private cleanupFns: Array<() => void> = [];
		private activeCard: HTMLElement | null = null;
		private nextZIndex = 20;

		connectedCallback() {
			this.stage = this.querySelector("[data-stage]");
			this.shell = this.querySelector("[data-board-shell]");
			this.cards = Array.from(this.querySelectorAll("[data-picture-card]"));
			this.infoPanel = this.querySelector("[data-picture-info]");
			this.infoText = this.querySelector("[data-picture-info-text]");
			this.dataset.ready = "false";

			if (!(this.stage instanceof HTMLElement) || this.cards.length === 0) {
				return;
			}

			window.requestAnimationFrame(() => {
				this.syncAllCardRatios();
				this.layoutCards();
				this.clampCards();
				this.dataset.ready = "true";
			});

			this.setupParallax();
			this.cards.forEach((card) => this.bindCard(card));
			this.resizeObserver = new ResizeObserver(() => this.clampCards());
			this.resizeObserver.observe(this.stage);

			if (!this.hasFineHover()) {
				const onStagePointerDown = (event: PointerEvent) => {
					const target = event.target;
					if (!(target instanceof Element)) return;
					if (target.closest("[data-picture-card]")) return;
					this.setActiveCard(null);
				};
				this.stage.addEventListener("pointerdown", onStagePointerDown);
				this.cleanupFns.push(() => {
					this.stage?.removeEventListener("pointerdown", onStagePointerDown);
				});
			}
		}

		disconnectedCallback() {
			this.resizeObserver?.disconnect();
			this.cleanupFns.forEach((cleanup) => cleanup());
			this.cleanupFns = [];
		}

		private syncAllCardRatios() {
			for (const card of this.cards) {
				this.syncCardRatio(card);
			}
		}

		private getEdgePadding() {
			if (window.innerWidth <= 640) return 6;
			if (window.innerWidth <= 900) return 10;
			return 14;
		}

		private hasFineHover() {
			return window.matchMedia("(hover: hover) and (pointer: fine)").matches;
		}

		private setInfoText(title: string, description: string) {
			if (!(this.infoPanel instanceof HTMLElement) || !(this.infoText instanceof HTMLElement)) return;

			if (!description) {
				this.infoPanel.dataset.active = "false";
				this.infoText.textContent = "";
				return;
			}

			this.infoPanel.dataset.active = "true";
			this.infoText.textContent = title ? `${title} · ${description}` : description;
		}

		private setActiveCard(card: HTMLElement | null) {
			if (this.activeCard && this.activeCard !== card) {
				this.activeCard.dataset.selected = "false";
			}

			if (!card) {
				this.activeCard = null;
				this.setInfoText("", "");
				return;
			}

			const isSameCard = this.activeCard === card;
			if (isSameCard) {
				card.dataset.selected = "false";
				this.activeCard = null;
				this.setInfoText("", "");
				return;
			}

			this.activeCard = card;
			card.dataset.selected = "true";
			this.setInfoText(card.dataset.title || "", card.dataset.description || "");
		}

		private setupParallax() {
			if (!(this.shell instanceof HTMLElement)) return;
			if (!window.matchMedia("(pointer: fine)").matches) return;
			if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

			let frame = 0;
			let currentX = 0;
			let currentY = 0;
			let targetX = 0;
			let targetY = 0;

			const tick = () => {
				currentX += (targetX - currentX) * 0.14;
				currentY += (targetY - currentY) * 0.14;

				this.shell?.style.setProperty("--board-shift-x", `${currentX.toFixed(2)}px`);
				this.shell?.style.setProperty("--board-shift-y", `${currentY.toFixed(2)}px`);

				if (
					Math.abs(targetX - currentX) < 0.08 &&
					Math.abs(targetY - currentY) < 0.08 &&
					Math.abs(currentX) < 0.08 &&
					Math.abs(currentY) < 0.08
				) {
					frame = 0;
					this.shell?.style.setProperty("--board-shift-x", "0px");
					this.shell?.style.setProperty("--board-shift-y", "0px");
					return;
				}

				frame = window.requestAnimationFrame(tick);
			};

			const ensureFrame = () => {
				if (frame !== 0) return;
				frame = window.requestAnimationFrame(tick);
			};

			const onMove = (event: PointerEvent) => {
				const rect = this.shell?.getBoundingClientRect();
				if (!rect) return;

				const relativeX = (event.clientX - rect.left) / rect.width - 0.5;
				const relativeY = (event.clientY - rect.top) / rect.height - 0.5;

				targetX = relativeX * 18;
				targetY = relativeY * 14;
				if (this.shell) {
					this.shell.dataset.parallax = "active";
				}
				ensureFrame();
			};

			const reset = () => {
				targetX = 0;
				targetY = 0;
				if (this.shell) {
					this.shell.dataset.parallax = "idle";
				}
				ensureFrame();
			};

			this.shell.addEventListener("pointermove", onMove);
			this.shell.addEventListener("pointerleave", reset);
			this.cleanupFns.push(() => {
				if (frame !== 0) {
					window.cancelAnimationFrame(frame);
				}
				this.shell?.removeEventListener("pointermove", onMove);
				this.shell?.removeEventListener("pointerleave", reset);
			});
		}

		private syncCardRatio(card: HTMLElement) {
			const image = card.querySelector("img");
			if (!(image instanceof HTMLImageElement)) return;

			const applyRatio = () => {
				if (!image.naturalWidth || !image.naturalHeight) return;

				card.style.setProperty(
					"--picture-ratio",
					`${image.naturalWidth} / ${image.naturalHeight}`,
				);
				this.clampCards();
			};

			if (image.complete) {
				applyRatio();
				return;
			}

			image.addEventListener("load", applyRatio, { once: true });
		}

		private layoutCards() {
			if (!(this.stage instanceof HTMLElement)) return;

			const stageWidth = this.stage.clientWidth;
			const stageHeight = this.stage.clientHeight;
			const edgePadding = this.getEdgePadding();

			for (const card of this.cards) {
				const x = Number(card.dataset.x || 0);
				const y = Number(card.dataset.y || 0);
				const width = card.offsetWidth;
				const height = card.offsetHeight;
				const maxLeft = Math.max(stageWidth - width - edgePadding * 2, 0);
				const maxTop = Math.max(stageHeight - height - edgePadding * 2, 0);

				card.style.left = `${edgePadding + (maxLeft * x) / 100}px`;
				card.style.top = `${edgePadding + (maxTop * y) / 100}px`;
				card.style.zIndex = String(this.nextZIndex++);
			}
		}

		private clampCards() {
			if (!(this.stage instanceof HTMLElement)) return;

			const stageWidth = this.stage.clientWidth;
			const stageHeight = this.stage.clientHeight;
			const edgePadding = this.getEdgePadding();

			for (const card of this.cards) {
				const maxLeft = Math.max(stageWidth - card.offsetWidth - edgePadding * 2, 0);
				const maxTop = Math.max(stageHeight - card.offsetHeight - edgePadding * 2, 0);
				const left = Number.parseFloat(card.style.left || "0");
				const top = Number.parseFloat(card.style.top || "0");

				card.style.left = `${this.clamp(left, edgePadding, edgePadding + maxLeft)}px`;
				card.style.top = `${this.clamp(top, edgePadding, edgePadding + maxTop)}px`;
			}
		}

		private bindCard(card: HTMLElement) {
			let pointerId = -1;
			let startX = 0;
			let startY = 0;
			let initialLeft = 0;
			let initialTop = 0;
			let moved = false;
			let settleTimer = 0;
			const dragThreshold = 10;
			const usesHoverDescription = this.hasFineHover();
			const bringToFront = () => {
				card.style.zIndex = String(this.nextZIndex++);
			};
			const showDescription = () => {
				card.dataset.selected = "true";
				this.setInfoText(card.dataset.title || "", card.dataset.description || "");
			};
			const clearDescription = () => {
				if (this.activeCard === card) return;
				card.dataset.selected = "false";
				this.setInfoText("", "");
			};

			const onPointerMove = (event: PointerEvent) => {
				if (!(this.stage instanceof HTMLElement) || event.pointerId !== pointerId) return;

				const deltaX = event.clientX - startX;
				const deltaY = event.clientY - startY;
				const edgePadding = this.getEdgePadding();

				const hasMoved = Math.abs(deltaX) > dragThreshold || Math.abs(deltaY) > dragThreshold;
				if (hasMoved && !moved) {
					card.dataset.dragging = "true";
				}
				moved = moved || hasMoved;

				const maxLeft = Math.max(
					this.stage.clientWidth - card.offsetWidth - edgePadding * 2,
					0,
				);
				const maxTop = Math.max(
					this.stage.clientHeight - card.offsetHeight - edgePadding * 2,
					0,
				);

				card.style.left = `${this.clamp(
					initialLeft + deltaX,
					edgePadding,
					edgePadding + maxLeft,
				)}px`;
				card.style.top = `${this.clamp(
					initialTop + deltaY,
					edgePadding,
					edgePadding + maxTop,
				)}px`;
			};

			const finishPointer = (event: PointerEvent) => {
				if (event.pointerId !== pointerId) return;

				if (card.hasPointerCapture(pointerId)) {
					card.releasePointerCapture(pointerId);
				}
				card.removeEventListener("pointermove", onPointerMove);
				card.removeEventListener("pointerup", finishPointer);
				card.removeEventListener("pointercancel", finishPointer);

				if (event.type === "pointerup" && !moved && !usesHoverDescription) {
					this.setActiveCard(card);
				}

				pointerId = -1;
				card.dataset.dragging = "false";
				window.clearTimeout(settleTimer);
				card.dataset.settling = "true";
				settleTimer = window.setTimeout(() => {
					delete card.dataset.settling;
				}, 180);
			};

			card.addEventListener("pointerdown", (event: PointerEvent) => {
				if (!(this.stage instanceof HTMLElement)) return;
				if (!event.isPrimary || event.button !== 0) return;

				pointerId = event.pointerId;
				startX = event.clientX;
				startY = event.clientY;
				initialLeft = Number.parseFloat(card.style.left || "0");
				initialTop = Number.parseFloat(card.style.top || "0");
				moved = false;

				card.style.zIndex = String(this.nextZIndex++);
				card.dataset.dragging = "false";
				delete card.dataset.settling;
				card.setPointerCapture(pointerId);
				card.addEventListener("pointermove", onPointerMove);
				card.addEventListener("pointerup", finishPointer);
				card.addEventListener("pointercancel", finishPointer);
			});

			card.addEventListener("dragstart", (event: DragEvent) => {
				event.preventDefault();
			});
			card.addEventListener("pointerenter", () => {
				bringToFront();
				if (usesHoverDescription) {
					showDescription();
				}
			});
			card.addEventListener("pointerleave", () => {
				if (usesHoverDescription) {
					clearDescription();
				}
			});
			card.addEventListener("focus", showDescription);
			card.addEventListener("blur", () => {
				if (usesHoverDescription || this.activeCard !== card) {
					clearDescription();
				}
			});
			this.cleanupFns.push(() => {
				window.clearTimeout(settleTimer);
			});
		}

		private clamp(value: number, min: number, max: number) {
			return Math.min(Math.max(value, min), max);
		}
	}

	if (!customElements.get("pictures-board")) {
		customElements.define("pictures-board", PicturesBoard);
	}
</script>
